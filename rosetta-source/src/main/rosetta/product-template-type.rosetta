        [metadata reference]
    bespokeExpression BespokeExpression (0..1) <"Any bespoke name or description that may be specified with string values (including values corresponding to mathematical expressions, when any).">
    selectedValue RankingObservation (0..*) <"The observable selected with the respective rank, represented by the associated dated quantity value">
        [metadata reference]

    condition OnlyMinOrMax: 
        rankingDirection = ArithmeticOperationEnum -> Min 
        or rankingDirection = ArithmeticOperationEnum -> Max
        and rankingDirection <> ArithmeticOperationEnum -> Add
        and rankingDirection <> ArithmeticOperationEnum -> Subtract
        and rankingDirection <> ArithmeticOperationEnum -> Multiply
        and rankingDirection <> ArithmeticOperationEnum -> Divide

    condition RanksSelection:  <"This attribute shall be used when there are multiple values being selected ; meaning that when only 1 value is being selected, mainly for representing base features such as straight Worst Of or straight Best Of ranking, then this attributes shall not be populated.">
        if  ranksSelection exists 
        then ranksSelection count > 1

    condition ReferenceObservablePriceType:
        if referenceObservablePriceType exists 
        then referenceObservable exists 

type WeightedRank: // FORK_2

    nthRank int (1..1)
    nthRankWeight number (0..1)

    condition Weight: <"The value of gthe weight cannot exceed 100%.">
    if nthRankWeight exists then nthRankWeight < 1

type RankingObservation extends WeightedRank :// FORK_2
    [metadata key]

    referenceObservable NewObservable (1..1)
        [metadata reference]
    observationDate date (1..1)

type Leverage : <"Represents the functional operation [ F(X) = X * N ] or the functional operation [ F(X) = X / D ] where: [N] is a Numerator value, [D] is a Denominator value ; and [X] is the value of the object for which this attribute is defined. If any, multiple instances represent a straight concatenation of such operations e.g. say n+m attributes would be populated: numerator [N1], Numerator [N2], ..., Numerator [Nn] exist, also possiby with Denominator [D1], Denominator [D2], ..., Denominator [Dm] then this would represent [ F(X) = X * N1 * N2 * ... * Nn * 1/D1 * 1/D2 * ... * 1/Dm ]."> // FORK_2
    [metadata key]

    referenceObservable NewObservable (0..1)
        [metadata reference]
    referenceObservablePriceType PriceTypeEnum (0..1) <"Provides enumerated values for types of prices in order to explain how to interpret it and use it in calculations.">
    multiplierResetDate DateRelativeToEnum (1..1) // FORK_4 not pushed yet
    observationTerms ObservationTerms (0..1)
        [metadata reference]
    numerator ObservablePriceQuantity (0..*)
    divisor ObservablePriceQuantity (0..*)
    bespokeExpression BespokeExpression (0..1) <"Any bespoke name or description that may be specified with string values (including values corresponding to mathematical expressions, when any).">
    calculatedValue CalculationValue (0..1) <"The numerical value or dated value which corresponds to the resolved value of the parent object for which this attribute is populated.">
        [metadata reference]


type QuantityCumulation: <"Specifies cumulation dates i.e. dates on which a given quantity is incremented over time. As an indication, products for which such feature is used are often referred to as Accumulator or Decumulator."> // FORK_2
    [metadata key]

    incrementalQuantity Quantity (1..1) <"Specifies the individual quantity that is being incremented/cumulated over time."> // no metadata address on this one because it is supposed to be fixed over time
    cumulationResetDate DateRelativeToEnum (1..1) <"Specifies the cumulation dates i.e. dates on which the referenced quantity is incremented over time.">
    guaranteedCumulationPeriod ObservationPeriodSchedule (0..*) <"The schedule periods for which the cumulation is guarenteed untill the end of the period, notwithstanding the occurrence of an any early termination, elsewhere defined in the trade documentation.">
    calculatedValue CalculationValue (0..1) <"The numerical value or dated value which corresponds to the resolved value of the parent object for which this attribute is populated.">
        [metadata reference]
