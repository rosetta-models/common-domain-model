typeAlias OrigSecondaryTradeID_t: <"Used to preserve original secondary trade id when original trade is being referenced in a subsequent trade transaction such as a transfer">
    string

typeAlias RefCstmApplVerID_t: <"Specifies a custom extension to a message being applied at the session level.">
    string

typeAlias TZTransactTime_t: <"Transact time in the local date-time stamp with a TZ offset to UTC identified">
    zonedDateTime

