typeAlias PaymentStreamLinkClosingLevelIndicator_t: <"Indicates whether the correlation or variance swap contract will (\"Y\") strike off the closing level of the default exchange traded contract or not.">
    cdm.fixml.datatypes.Boolean

typeAlias PaymentStreamLinkExpiringLevelIndicator_t: <"Indicates whether the correlation or variance swap contract will (\"Y\") strike off the expiring level of the default exchange traded contract or not.">
    cdm.fixml.datatypes.Boolean

typeAlias PaymentStreamLinkEstimatedTradingDays_t: <"The expected number of trading days in the variance or correlation swap stream.">
    int

typeAlias PaymentStreamLinkStrikePrice_t: <"The strike price of a correlation or variance swap stream.">
    cdm.fixml.datatypes.Price

typeAlias PaymentStreamLinkMaximumBoundary_t: <"Specifies the maximum or upper boundary for variance or strike determination.  For a variation swap stream all observations above this price level will be excluded from the variance calculation.  For a correlation swap stream the maximum boundary is a percentage of the strike price.">
    number

typeAlias PaymentStreamLinkMinimumBoundary_t: <"Specifies the minimum or lower boundary for variance or strike determination.  For a variation swap stream all observations below this price level will be excluded from the variance calculation.  For a correlation swap stream the minimum boundary is a percentage of the strike price.">
    number

typeAlias PaymentStreamLinkNumberOfDataSeries_t: <"Number of data series for a correlation swap. Normal market practice is that correlation data sets are drawn from geographic market areas, such as America, Europe and Asia Pacific. Each of these geographic areas will have its own data series to avoid contagion.">
    int

typeAlias PaymentStreamVarianceUnadjustedCap_t: <"Indicates the scaling factor to be multiplied by the variance strike price thereby making variance cap applicable.">
    number

typeAlias PaymentStreamDaysAdjustmentIndicator_t: <"Indicates whether the contract specifies that the notional should be scaled by the number of days in range divided by the estimate trading days or not. The number of \"days in range\" refers to the number of returns that contribute to the realized volatility.">
    cdm.fixml.datatypes.Boolean

typeAlias PaymentStreamNearestExchangeContractRefID_t: <"References a contract listed on an exchange through the instrument\'s UnderlyingSecurityID(309) which must be fully specified in an instance of the UnderlyingInstrument component.">
    string

typeAlias PaymentStreamVegaNotionalAmount_t: <"\"Vega Notional\" represents the approximate gain/loss at maturity for a 1% difference between RVol (realised volatility) and KVol (strike volatility). It does not necessarily represent the Vega risk of the trade.">
    number

typeAlias PaymentStreamFormula_t: <"Contains an XML representation of the formula. Defined for flexibility in choice of language (MathML, OpenMath or text).">
    cdm.fixml.datatypes.XMLData

typeAlias PaymentStreamFormulaDesc_t: <"A description of the math formula in PaymentStreamFormula(42684).">
    string

typeAlias PaymentStreamFormulaCurrency_t: <"The currency in which the formula amount is denominated. Uses ISO 4217 currency codes.">
    cdm.fixml.datatypes.Currency

typeAlias PaymentStreamFormulaCurrencyDeterminationMethod_t: <"Specifies the method according to which the formula amount currency is determined.  See http://www.fpml.org/coding-scheme/determination-method for values.">
    string

typeAlias PaymentStreamFormulaReferenceAmount_t: <"Specifies the reference amount when this term either corresponds to the standard ISDA Definition (either the 2002 Equity Definition for the Equity Amount, or the 2000 Definition for the Interest Amount), or refers to a term defined elsewhere in the swap document.  See http://www.fixtradingcommunity.org/codelists#Payment_Amount_Relative_To for code list of reference amounts.">
    int

