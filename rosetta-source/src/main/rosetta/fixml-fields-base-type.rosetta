    cdm.fixml.datatypes.Boolean

typeAlias RptSys_t: <"Indicates the system or medium on which the report has been published">
    string

typeAlias AllocClearingFeeIndicator_t: <"ClearingFeeIndicator(635) for Allocation, see ClearingFeeIndicator(635) for permitted values.">
    string

typeAlias DisplayQty_t: <"The quantity to be displayed . Required for reserve orders. On orders specifies the qty to be displayed, on execution reports the currently displayed quantity.">
