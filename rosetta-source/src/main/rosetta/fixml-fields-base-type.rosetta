typeAlias UnderlyingFXRate_t: <"Foreign exchange rate used to compute UnderlyingCurrentValue(885) (or market value) from UnderlyingCurrency(318) to Currency(15).">
    number

typeAlias InstrumentPartySubID_t: <"PartySubID value within an instrument party repeating group.  Same values as PartySubID (523)">
    string

typeAlias PositionCurrency_t: <"The Currency in which the position Amount is denominated">
    string

typeAlias CalculatedCcyLastQty_t: <"Used for the calculated quantity of the other side of the currency trade. Can be derived from LastQty and LastPx.">
    cdm.fixml.datatypes.Qty

typeAlias UnderlyingInstrumentPartyID_t: <"PartyID value within an underlying instrument party repeating group.  Same values as PartyID (448)">
    string

typeAlias UnderlyingInstrumentPartySubID_t: <"PartySubID value within an underlying instrument party repeating group.  Same values as PartySubID (523)">
    string

typeAlias BidSwapPoints_t: <"The bid FX Swap points for an FX Swap. It is the \"far bid forward points - near offer forward point\". Value can be negative. Expressed in decimal form. For example, 61.99 points is expressed and sent as 0.006199">
    cdm.fixml.datatypes.PriceOffset

typeAlias OfferSwapPoints_t: <"The offer FX Swap points for an FX Swap. It is the \"far offer forward points - near bid forward points\". Value can be negative. Expressed in decimal form. For example, 61.99 points is expressed and sent as 0.006199">
    cdm.fixml.datatypes.PriceOffset

typeAlias LegBidForwardPoints_t: <"The bid FX forward points for the leg of an FX Swap. Value can be negative. Expressed in decimal form. For example, 61.99 points is expressed and sent as 0.006199">
    cdm.fixml.datatypes.PriceOffset

typeAlias LegOfferForwardPoints_t: <"The offer FX forward points for the leg of an FX Swap. Value can be negative. Expressed in decimal form. For example, 61.99 points is expressed and sent as 0.006199">
    cdm.fixml.datatypes.PriceOffset

typeAlias SwapPoints_t: <"For FX Swap, this is used to express the differential between the far leg\'s bid/offer and the near leg\'s bid/offer. Value can be negative. Expressed in decimal form. For example, 61.99 points is expressed and sent as 0.006199">
    cdm.fixml.datatypes.PriceOffset

typeAlias LastSwapPoints_t: <"For FX Swap, this is used to express the last market event for the differential between the far leg\'s bid/offer and the near leg\'s bid/offer in a fill or partial fill. Value can be negative. Expressed in decimal form. For example, 61.99 points is expressed and sent as 0.006199">
    cdm.fixml.datatypes.PriceOffset

typeAlias SideGrossTradeAmt_t: <"The gross trade amount for this side of the trade. See also GrossTradeAmt (381) for additional definition.">
    cdm.fixml.datatypes.Amt

typeAlias LegLastForwardPoints_t: <"The forward points for this leg\'s fill event. Value can be negative. Expressed in decimal form. For example, 61.99 points is expressed and sent as 0.006199">
    cdm.fixml.datatypes.PriceOffset

typeAlias LegCalculatedCcyLastQty_t: <"Used for the calculated quantity of the other side of the currency for this leg. Can be derived from LegQty and LegLastPx.">
    cdm.fixml.datatypes.Qty

typeAlias LegGrossTradeAmt_t: <"The gross trade amount of the leg. For FX Futures this is used to express the notional value of a fill when LegLastQty and other quantity fields are express in terms of contract size.">
    cdm.fixml.datatypes.Amt

typeAlias MaturityTime_t: <"Time of security\'s maturity expressed in local time with offset to UTC specified">
    time

typeAlias RefOrderID_t: <"The ID reference to the order being hit or taken.  For pre-trade credit/risk limit check process, this is the reference to the placed order, quote request or quote for the credit/risk limit check.">
    string

typeAlias SecondaryDisplayQty_t: <"Used for reserve orders when DisplayQty applies to the primary execution market (e.g.an ECN) and another quantity is to be shown at other markets (e.g. the exchange). On orders specifies the qty to be displayed, on execution reports the currently displayed quantity.">
    cdm.fixml.datatypes.Qty

typeAlias DisplayLowQty_t: <"Defines the lower quantity limit to a randomized refresh of DisplayQty.">
    cdm.fixml.datatypes.Qty

typeAlias DisplayHighQty_t: <"Defines the upper quantity limit to a randomized refresh of DisplayQty.">
    cdm.fixml.datatypes.Qty

typeAlias DisplayMinIncr_t: <"Defines the minimum increment to be used when calculating a random refresh of DisplayQty. A user specifies this when he wants a larger increment than the standard provided by the market (e.g. the round lot size).">
    cdm.fixml.datatypes.Qty

typeAlias RefreshQty_t: <"Defines the quantity used to refresh DisplayQty.">
    cdm.fixml.datatypes.Qty

typeAlias MatchIncrement_t: <"Allows orders to specify a minimum quantity that applies to every execution (one execution could be for multiple counter-orders). The order may still fill against smaller orders, but the cumulative quantity of the execution must be in multiples of the MatchIncrement.">
    cdm.fixml.datatypes.Qty

typeAlias MaxPriceLevels_t: <"Allows an order to specify a maximum number of price levels to trade through. Only valid for aggressive orders and during continuous (autoexecution) trading sessions. Property lost when order is put on book. A partially filled order is assigned last trade price as limit price. Non-filled order behaves as ordinary Market or Limit.">
    int

typeAlias PreTradeAnonymity_t: <"Allows trader to explicitly request anonymity or disclosure in pre-trade market data feeds. Anonymity is relevant in markets where counterparties are regularly disclosed in order depth feeds. Disclosure is relevant when counterparties are not normally visible.">
    cdm.fixml.datatypes.Boolean

typeAlias PeggedRefPrice_t: <"The value of the reference price that the order is pegged to. PeggedRefPrice + PegOffsetValue (211) = PeggedPrice (839) unless the limit price (44, Price) is breached. The values may not be exact due to rounding.">
    cdm.fixml.datatypes.Price

typeAlias PegSecurityID_t: <"Defines the identity of the security off whose prices the order will peg.">
    string

typeAlias PegSymbol_t: <"Defines the common, \'human understood\' representation of the security off whose prices the order will Peg.">
    string

typeAlias PegSecurityDesc_t: <"Security description of the security off whose prices the order will Peg.">
    string

typeAlias TriggerPrice_t: <"The price at which the trigger should hit.">
    cdm.fixml.datatypes.Price

typeAlias TriggerSymbol_t: <"Defines the common, \'human understood\' representation of the security whose prices will be tracked by the trigger logic.">
    string

typeAlias TriggerSecurityID_t: <"Defines the identity of the security whose prices will be tracked by the trigger logic.">
    string

typeAlias TriggerSecurityDesc_t: <"Defines the security description of the security whose prices will be tracked by the trigger logic.">
    string

typeAlias TriggerNewPrice_t: <"The Price that the order should have after the trigger has hit. Could be applicable for any trigger type, but must be specified for Trigger Type 1.">
    cdm.fixml.datatypes.Price

typeAlias TriggerNewQty_t: <"The Quantity the order should have after the trigger has hit.">
    cdm.fixml.datatypes.Qty

typeAlias RootPartyID_t: <"PartyID value within a root parties component. Same values as PartyID (448)">
    string

typeAlias RootPartySubID_t: <"PartySubID value within a root parties component. Same values as PartySubID (523)">
    string

typeAlias OrigTradeDate_t: <"Used to preserve original trade date when original trade is being referenced in a subsequent trade transaction such as a transfer">
    cdm.fixml.datatypes.LocalMktDate

typeAlias OrigTradeID_t: <"Used to preserve original trade id when original trade is being referenced in a subsequent trade transaction such as a transfer">
