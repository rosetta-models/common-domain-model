    cdm.fixml.datatypes.LocalMktDate

typeAlias UnderlyingPaymentScheduleWeight_t: <"Floating rate observation weight for cashflow payment.">
    number

typeAlias UnderlyingPaymentScheduleFixingDateRelativeTo_t: <"Specifies the anchor date when the fixing date is relative to an anchor date.  See http://www.fixtradingcommunity.org/codelists#Relative_To_Date for values.">
    int

typeAlias UnderlyingPaymentScheduleFixingDateBusinessCenter_t: <"The business center calendar used to adjust the payment schedule\'s fixing date, e.g. \"GBLO\". See http://www.fpml.org/coding-scheme/business-center for standard 4-character code values.">
    string

typeAlias UnderlyingPaymentScheduleFixingDateOffsetPeriod_t: <"Time unit multiplier for the relative fixing date offset.">
    int

