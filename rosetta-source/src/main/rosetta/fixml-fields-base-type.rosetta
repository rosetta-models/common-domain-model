typeAlias LegPaymentStreamLinkInitialLevel_t: <"Price level at which the correlation or variance swap contract will strike.">
    cdm.fixml.datatypes.Price

typeAlias LegPaymentStreamLinkClosingLevelIndicator_t: <"Indicates whether the correlation or variance swap contract will (\"Y\") strike off the closing level of the default exchange traded contract or not.">
    cdm.fixml.datatypes.Boolean

typeAlias LegPaymentStreamLinkExpiringLevelIndicator_t: <"Indicates whether the correlation or variance swap contract will (\"Y\") strike off the expiring level of the default exchange traded contract or not.">
    cdm.fixml.datatypes.Boolean

