    string

typeAlias UnderlyingStreamCommodityCurrency_t: <"Identifies the currency of the commodity asset. Uses ISO 4217 currency codes.">
    cdm.fixml.datatypes.Currency

typeAlias UnderlyingStreamCommodityExchange_t: <"Identifies the exchange where the commodity is traded.">
    cdm.fixml.datatypes.Exchange

