    cdm.fixml.datatypes.Percentage

typeAlias LegPaymentStubIndex2FloorRate_t: <"The floor rate, if any, which applies to the second floating rate. The floor rate (strike) is only required where the floating rate on a swap stream is floored at a certain strike level. The floor rate is assumed to be exclusive of any spread and is a per annum rate, expressed as a decimal. A floor rate of 5% would be represented as 0.05.">
    cdm.fixml.datatypes.Percentage

typeAlias LegProvisionDateUnadjusted_t: <"The unadjusted date of the provision.">
    cdm.fixml.datatypes.LocalMktDate

typeAlias LegProvisionDateBusinessCenter_t: <"The business center calendar used to adjust the instrument leg\'s provision\'s date, e.g. \"GBLO\". See http://www.fpml.org/coding-scheme/business-center for standard 4-character code values.">
    string

typeAlias LegProvisionDateAdjusted_t: <"The adjusted date of the provision.">
    cdm.fixml.datatypes.LocalMktDate

typeAlias LegProvisionDateTenorPeriod_t: <"Time unit multiplier for the leg provision\'s tenor period.">
    int

typeAlias LegProvisionOptionExerciseMultipleNotional_t: <"A notional amount which restricts the amount of notional that can be exercised when partial exercise or multiple exercise is applicable. The integral multiple amount defines a lower limit of notional that can be exercised and also defines a unit multiple of notional that can be exercised, i.e. only integer multiples of this amount can be exercised.">
    cdm.fixml.datatypes.Amt

typeAlias LegProvisionOptionExerciseMinimumNotional_t: <"The minimum notional amount that can be exercised on a given exercise date.">
    cdm.fixml.datatypes.Amt

typeAlias LegProvisionOptionExerciseMaximumNotional_t: <"The maximum notional amount that can be exercised on a given exercise date.">
    cdm.fixml.datatypes.Amt

typeAlias LegProvisionOptionMinimumNumber_t: <"The minimum number of options that can be exercised on a given exercise date.">
    int

typeAlias LegProvisionOptionMaximumNumber_t: <"The maximum number of options that can be exercised on a given exercise date. If the number is not specified, it means that the maximum number of options corresponds to the remaining unexercised options.">
    int

typeAlias LegProvisionOptionExerciseConfirmation_t: <"Used to indicate whether follow-up confirmation of exercise (written or electronic) is required following telephonic notice by the buyer to the seller or seller\'s agent.">
    cdm.fixml.datatypes.Boolean

typeAlias LegProvisionCashSettlCurrency_t: <"Specifies the currency of settlement. Uses ISO 4217 currency codes.">
    cdm.fixml.datatypes.Currency

typeAlias LegProvisionCashSettlCurrency2_t: <"Specifies the currency of settlement for a cross-currency provision. Uses ISO 4217 currency codes.">
    cdm.fixml.datatypes.Currency

typeAlias BusinessCenter_t: <"A business center whose calendar is used for date adjustment, e.g. \"GBLO\". See http://www.fpml.org/coding-scheme/business-center for standard 4-character code values.">
    string

typeAlias LegProvisionText_t: <"Free form text to specify additional information or enumeration description when a standard value does not apply.">
    string

typeAlias LegProvisionCashSettlPaymentDate_t: <"The cash settlement payment date, unadjusted or adjusted depending on LegProvisionCashSettlPaymentDateType(40521).">
    cdm.fixml.datatypes.LocalMktDate

typeAlias LegProvisionOptionExerciseBusinessCenter_t: <"The business center calendar used to adjust the instrument leg\'s provision\'s option exercise date, e.g. \"GBLO\".  See http://www.fpml.org/coding-scheme/business-center for standard 4-character code values.">
    string

typeAlias LegProvisionOptionExerciseEarliestDateOffsetPeriod_t: <"Time unit multiplier for the interval to the first (and possibly only) exercise date in the exercise period.">
    int

typeAlias LegProvisionOptionExerciseFrequencyPeriod_t: <"Time unit multiplier for subsequent exercise dates in the exercise period following the earliest exercise date. An interval of 1 day should be used to indicate an American style exercise period.">
    int

typeAlias LegProvisionOptionExerciseStartDateUnadjusted_t: <"The unadjusted first day of the exercise period for an American style option.">
    cdm.fixml.datatypes.LocalMktDate

typeAlias LegProvisionOptionExerciseStartDateRelativeTo_t: <"Specifies the anchor date when the option exercise start date is relative to an anchor date.  See http://www.fixtradingcommunity.org/codelists#Relative_To_Date for values.">
    int

typeAlias LegProvisionOptionExerciseStartDateOffsetPeriod_t: <"Time unit multiplier for the relative option exercise start date offset.">
    int

typeAlias LegProvisionOptionExerciseStartDateAdjusted_t: <"The adjusted first day of the exercise period for an American style option.">
    cdm.fixml.datatypes.LocalMktDate

typeAlias LegProvisionOptionExercisePeriodSkip_t: <"The number of periods in the referenced date schedule that are between each date in the relative date schedule. Thus a skip of 2 would mean that dates are relative to every second date in the referenced schedule. If present this should have a value greater than 1.">
    int

typeAlias LegProvisionOptionExerciseBoundsFirstDateUnadjusted_t: <"The unadjusted first date of a schedule. This can be used to restrict the range of exercise dates when they are relative.">
    cdm.fixml.datatypes.LocalMktDate

typeAlias LegProvisionOptionExerciseBoundsLastDateUnadjusted_t: <"The unadjusted last date of a schedule. This can be used to restrict the range of exercise dates when they are relative.">
    cdm.fixml.datatypes.LocalMktDate

typeAlias LegProvisionOptionExerciseEarliestTime_t: <"The earliest time at which notice of exercise can be given by the buyer to the seller (or seller\'s agent) (i) on the expriation date, in the case of a European style option, (ii) on each bermuda option exercise date and the expiration date, in the case of a Bermuda style option the commencement date to, and including, the expiration date, in the case of an American option.">
    time

typeAlias LegProvisionOptionExerciseEarliestTimeBusinessCenter_t: <"Identifies the business center calendar used with the provision\'s earliest time for notice of exercise.  See http://www.fpml.org/coding-scheme/business-center for standard 4-character code values.">
    string

typeAlias LegProvisionOptionExerciseLatestTime_t: <"For a Bermuda or American style option, the latest time on an exercise business day (excluding the expiration date) within the exercise period that notice can be given by the buyer to the seller or seller\'s agent. Notice of exercise given after this time will be deemed to have been given on the next exercise business day.">
    time

typeAlias LegProvisionOptionExerciseLatestTimeBusinessCenter_t: <"Identifies the business center calendar used with the provision\'s latest time for notice of exercise.  See http://www.fpml.org/coding-scheme/business-center for standard 4-character code values.">
    string

typeAlias LegProvisionOptionExerciseFixedDate_t: <"A predetermined option exercise date unadjusted or adjusted depending on LegProvisionOptionExerciseFixedDateType(40497).">
    cdm.fixml.datatypes.LocalMktDate

typeAlias LegProvisionOptionExpirationDateUnadjusted_t: <"The unadjusted last day within an exercise period for an American style option. For a European style option it is the only day within the exercise period.">
    cdm.fixml.datatypes.LocalMktDate

typeAlias LegProvisionOptionExpirationDateBusinessCenter_t: <"The business center calendar used to adjust the instrument leg\'s provision\'s option expiration date, e.g. \"GBLO\".  See http://www.fpml.org/coding-scheme/business-center for standard 4-character code values.">
    string

typeAlias LegProvisionOptionExpirationDateRelativeTo_t: <"Specifies the anchor date when the option expiration date is relative to an anchor date.  See http://www.fixtradingcommunity.org/codelists#Relative_To_Date for values.">
    int

typeAlias LegProvisionOptionExpirationDateOffsetPeriod_t: <"Time unit multiplier for the relative option expiration date offset.">
    int

typeAlias LegProvisionOptionExpirationDateAdjusted_t: <"The adjusted last date within an exercise period for an American style option. For a European style option it is the only date within the exercise period.">
    cdm.fixml.datatypes.LocalMktDate

typeAlias LegProvisionOptionExpirationTime_t: <"The latest time for exercise on the expiration date.">
    time

typeAlias LegProvisionOptionExpirationTimeBusinessCenter_t: <"Identifies the business center calendar used with the provision\'s latest exercise time on expiration date.  See http://www.fpml.org/coding-scheme/business-center for standard 4-character code values.">
    string

typeAlias LegProvisionOptionRelevantUnderlyingDateUnadjusted_t: <"The unadjusted date on the underlying set by the exercise of an option. What this date is depends on the option (e.g. in a swaption it is the swap effective date, in an extendible/cancelable provision it is the swap termination date).">
    cdm.fixml.datatypes.LocalMktDate

typeAlias LegProvisionOptionRelevantUnderlyingDateBusinessCenter_t: <"The business center calendar used to adjust the instrument leg\'s provision\'s option underlying date, e.g. \"GBLO\".  See http://www.fpml.org/coding-scheme/business-center for standard 4-character code values.">
    string

typeAlias LegProvisionOptionRelevantUnderlyingDateRelativeTo_t: <"Specifies the anchor date when the date relevant to the underlying trade on exercise is relative to an anchor date.  See http://www.fixtradingcommunity.org/codelists#Relative_To_Date for values.">
    int

typeAlias LegProvisionOptionRelevantUnderlyingDateOffsetPeriod_t: <"Time unit multiplier for the relative option relevant underlying date offset.">
    int

typeAlias LegProvisionOptionRelevantUnderlyingDateAdjusted_t: <"The adjusted date on the underlying set by the exercise of an option. What this date is depends on the option (e.g. in a swaption it is the swap effective date, in an extendible/cancelable provision it is the swap termination date).">
    cdm.fixml.datatypes.LocalMktDate

typeAlias LegProvisionCashSettlPaymentDateBusinessCenter_t: <"The business center calendar used to adjust the provisional cash settlement payment\'s termination, or relative termination, date, e.g. \"GBLO\".  See http://www.fpml.org/coding-scheme/business-center for standard 4-character code values.">
    string

typeAlias LegProvisionCashSettlPaymentDateRelativeTo_t: <"Specifies the anchor date when the cash settlement payment date is relative to an anchor date.  See http://www.fixtradingcommunity.org/codelists#Relative_To_Date for values.">
    int

typeAlias LegProvisionCashSettlPaymentDateOffsetPeriod_t: <"Time unit multiplier for the relative cash settlement payment date offset.">
    int

typeAlias LegProvisionCashSettlPaymentDateRangeFirst_t: <"The first date in range when a settlement date range is provided.">
    cdm.fixml.datatypes.LocalMktDate

typeAlias LegProvisionCashSettlPaymentDateRangeLast_t: <"The last date in range when a settlement date range is provided.">
    cdm.fixml.datatypes.LocalMktDate

typeAlias LegProvisionCashSettlValueTime_t: <"A time specified in 24-hour format, e.g. 11am would be represented as 11:00:00. The time of the cash settlement valuation date when the cash settlement amount will be determined according to the cash settlement method if the parties have not otherwise been able to agree to the cash settlement amount.">
    time

typeAlias LegProvisionCashSettlValueTimeBusinessCenter_t: <"Identifies the business center calendar used with the provision\'s cash settlement valuation time.  See http://www.fpml.org/coding-scheme/business-center for standard 4-character code values.">
    string

typeAlias LegProvisionCashSettlValueDateBusinessCenter_t: <"The business center calendar used to adjust the provision\'s cash settlement valuation date, e.g. \"GBLO\".  See http://www.fpml.org/coding-scheme/business-center for standard 4-character code values.">
    string

typeAlias LegProvisionCashSettlValueDateRelativeTo_t: <"Specifies the anchor date when the cash settlement value date is relative to an anchor date.  See http://www.fixtradingcommunity.org/codelists#Relative_To_Date for values.">
    int

typeAlias LegProvisionCashSettlValueDateOffsetPeriod_t: <"Time unit multiplier for the relative cash settlement value date offset.">
    int

typeAlias LegProvisionCashSettlValueDateAdjusted_t: <"The adjusted cash settlement value date.">
    cdm.fixml.datatypes.LocalMktDate

typeAlias LegProvisionPartyID_t: <"The party identifier/code for the payment settlement party.">
    string

typeAlias LegProvisionPartySubID_t: <"Party sub-identifier, if applicable, for LegProvisionPartyRole(40536).">
    string

typeAlias UnderlyingStreamDesc_t: <"A short descriptive name given to payment stream. Eg. CDS, Fixed, Float, Float2, GBP. The description has no intrinsic meaning but should be arbitrarily chosen by the remitter as a reference.">
    string

typeAlias UnderlyingStreamNotional_t: <"Notional, or initial notional value for the payment stream. Use SwapSchedule for steps.">
    cdm.fixml.datatypes.Amt

typeAlias UnderlyingStreamCurrency_t: <"Specifies the currency the UnderlyingStreamNotional(40545) is denominated in. Uses ISO 4217 currency codes.">
    cdm.fixml.datatypes.Currency

typeAlias UnderlyingStreamText_t: <"Free form text to specify additional information or enumeration description when a standard value does not apply.">
    string

typeAlias UnderlyingStreamTerminationDateUnadjusted_t: <"The unadjusted termination date.">
    cdm.fixml.datatypes.LocalMktDate

typeAlias UnderlyingStreamTerminationDateBusinessCenter_t: <"The business center calendar used to adjust the underlying instrument\'s stream\'s termination, or relative termination, date, e.g. \"GBLO\".  See http://www.fpml.org/coding-scheme/business-center for standard 4-character code values.">
    string

typeAlias UnderlyingStreamTerminationDateRelativeTo_t: <"Specifies the anchor date when the termination date is relative to an anchor date.  See http://www.fixtradingcommunity.org/codelists#Relative_To_Date for values.">
    int

typeAlias UnderlyingStreamTerminationDateOffsetPeriod_t: <"Time unit multiplier for the relative termination date offset.">
    int

typeAlias UnderlyingStreamTerminationDateAdjusted_t: <"The adjusted termination date.">
    cdm.fixml.datatypes.LocalMktDate

typeAlias UnderlyingStreamCalculationPeriodBusinessCenter_t: <"The business center calendar used to adjust the calculation periods, e.g. \"GBLO\".  See http://www.fpml.org/coding-scheme/business-center for standard 4-character code values.">
    string

typeAlias UnderlyingStreamFirstPeriodStartDateUnadjusted_t: <"The unadjusted first calculation period start date if before the effective date.">
    cdm.fixml.datatypes.LocalMktDate

typeAlias UnderlyingStreamFirstPeriodStartDateBusinessCenter_t: <"The business center calendar used to adjust the underlying instrument\'s stream\'s first calculation period start date, e.g. \"GBLO\".  See http://www.fpml.org/coding-scheme/business-center for standard 4-character code values.">
    string

typeAlias UnderlyingStreamFirstPeriodStartDateAdjusted_t: <"The adjusted first calculation period start date, if it is before the effective date.">
    cdm.fixml.datatypes.LocalMktDate

typeAlias UnderlyingStreamFirstRegularPeriodStartDateUnadjusted_t: <"The unadjusted first start date of the regular calculation period, if there is an initial stub period.">
    cdm.fixml.datatypes.LocalMktDate

typeAlias UnderlyingStreamFirstCompoundingPeriodEndDateUnadjusted_t: <"The unadjusted end date of the initial compounding period.">
    cdm.fixml.datatypes.LocalMktDate

typeAlias UnderlyingStreamLastRegularPeriodEndDateUnadjusted_t: <"The unadjusted last regular period end date if there is a final stub period.">
    cdm.fixml.datatypes.LocalMktDate

typeAlias UnderlyingStreamCalculationFrequencyPeriod_t: <"Time unit multiplier for the frequency at which calculation period end dates occur.">
    int

typeAlias UnderlyingPaymentStreamMarketRate_t: <"Used only for credit index trade. This contains the credit spread (\"fair value\") at which the trade was executed. The market rate varies over the life of the index depending on market conditions. This is the price of the index as quoted by trading desks.">
    int

typeAlias UnderlyingPaymentStreamDelayIndicator_t: <"Applicable to credit default swaps on mortgage backed securities to specify whether payment delays are applicable to the fixed amount.  Residential mortgage backed securities typically have a payment delay of 5 days between the coupon date of the reference obligation and the payment date of the synthetic swap.  Commercial mortage backed securities do not typically have a payment delay, with both payment dates (the coupon date of the reference obligation and the payment date of the synthetic swap) being on the 25th of each month.">
    cdm.fixml.datatypes.Boolean

typeAlias UnderlyingPaymentStreamSettlCurrency_t: <"Specifies the currency that the stream settles in (to support swaps that settle in a currency different from the notional currency). Uses ISO 4217 currency codes.">
    cdm.fixml.datatypes.Currency

typeAlias UnderlyingPaymentStreamAccrualDays_t: <"The number of days from the adjusted calculation period start date to the adjusted value date, calculated in accordance with the applicable day count fraction.">
    int

typeAlias UnderlyingPaymentStreamDiscountRate_t: <"Discount rate. The rate is expressed in decimal, e.g. 5% is expressed as 0.05.">
    cdm.fixml.datatypes.Percentage

typeAlias UnderlyingPaymentStreamInitialPrincipalExchangeIndicator_t: <"Indicates whether there is an initial exchange of principal on the effective date.">
    cdm.fixml.datatypes.Boolean

typeAlias UnderlyingPaymentStreamInterimPrincipalExchangeIndicator_t: <"Indicates whether there are intermediate or interim exchanges of principal during the term of the swap.">
    cdm.fixml.datatypes.Boolean

typeAlias UnderlyingPaymentStreamFinalPrincipalExchangeIndicator_t: <"Indicates whether there is a final exchange of principal on the termination date.">
    cdm.fixml.datatypes.Boolean

typeAlias UnderlyingPaymentStreamPaymentDateBusinessCenter_t: <"The business center calendar used to adjust the payment stream\'s payment date, e.g. \"GBLO\".  See http://www.fpml.org/coding-scheme/business-center for standard 4-character code values.">
    string

typeAlias UnderlyingPaymentStreamPaymentFrequencyPeriod_t: <"Time unit multiplier for the frequency of payments.">
    int

typeAlias UnderlyingPaymentStreamFirstPaymentDateUnadjusted_t: <"The unadjusted first payment date.">
    cdm.fixml.datatypes.LocalMktDate

typeAlias UnderlyingPaymentStreamLastRegularPaymentDateUnadjusted_t: <"The unadjusted last regular payment date.">
    cdm.fixml.datatypes.LocalMktDate

typeAlias UnderlyingPaymentStreamPaymentDateRelativeTo_t: <"Specifies the anchor date when payment dates are relative to an anchor date.  See http://www.fixtradingcommunity.org/codelists#Relative_To_Date for values.">
    int

typeAlias UnderlyingPaymentStreamPaymentDateOffsetPeriod_t: <"Time unit multiplier for the relative payment date offset.">
    int

typeAlias UnderlyingPaymentStreamResetDateRelativeTo_t: <"Specifies the anchor date when the reset dates are relative to an anchor date.  If the reset frequency is specified as daily this element must not be included.  See http://www.fixtradingcommunity.org/codelists#Relative_To_Date for values.">
    int

typeAlias UnderlyingPaymentStreamResetDateBusinessCenter_t: <"The business center calendar used to adjust the payment stream\'s reset date, e.g. \"GBLO\".  See http://www.fpml.org/coding-scheme/business-center for standard 4-character code values.">
    string

typeAlias UnderlyingPaymentStreamResetFrequencyPeriod_t: <"Time unit multiplier for frequency of resets.">
    int

typeAlias UnderlyingPaymentStreamInitialFixingDateRelativeTo_t: <"Specifies the anchor date when the initial fixing date is relative to an anchor date.  See http://www.fixtradingcommunity.org/codelists#Relative_To_Date for values.">
    int

typeAlias UnderlyingPaymentStreamInitialFixingDateBusinessCenter_t: <"The business center calendar used to adjust the payment stream\'s initial fixing date, e.g. \"GBLO\".  See http://www.fpml.org/coding-scheme/business-center for standard 4-character code values.">
    string

typeAlias UnderlyingPaymentStreamInitialFixingDateOffsetPeriod_t: <"Time unit multiplier for the relative initial fixing date offset.">
    int

typeAlias UnderlyingPaymentStreamInitialFixingDateAdjusted_t: <"The adjusted initial fixing date.">
    cdm.fixml.datatypes.LocalMktDate

typeAlias UnderlyingPaymentStreamFixingDateRelativeTo_t: <"Specifies the anchor date when the fixing date is relative to an anchor date.  See http://www.fixtradingcommunity.org/codelists#Relative_To_Date for values.">
    int

typeAlias UnderlyingPaymentStreamFixingDateBusinessCenter_t: <"The business center calendar used to adjust the payment stream\'s fixing date, e.g. \"GBLO\".  See http://www.fpml.org/coding-scheme/business-center for standard 4-character code values.">
    string

typeAlias UnderlyingPaymentStreamFixingDateOffsetPeriod_t: <"Time unit multiplier for the relative fixing date offset.">
    int

typeAlias UnderlyingPaymentStreamFixingDateAdjusted_t: <"The adjusted fixing date.">
    cdm.fixml.datatypes.LocalMktDate

typeAlias UnderlyingPaymentStreamRateCutoffDateOffsetPeriod_t: <"Time unit multiplier for the relative rate cut-off date offset.">
    int

typeAlias UnderlyingPaymentStreamRate_t: <"The rate applicable to the fixed rate payment stream.">
    cdm.fixml.datatypes.Percentage

typeAlias UnderlyingPaymentStreamFixedAmount_t: <"The underlying payment stream\'s fixed payment amount. In CDS an alternative to UnderlyingPaymentStreamRate(40615).">
    cdm.fixml.datatypes.Amt

typeAlias UnderlyingPaymentStreamRateOrAmountCurrency_t: <"Specifies the currency in which UnderlyingPaymentStreamFixedAmount(40616) or UnderlyingPaymentStreamRate(40615) is denominated. Users ISO 4271 currency codes.">
    cdm.fixml.datatypes.Currency

typeAlias UnderlyingPaymentStreamFutureValueNotional_t: <"The future value notional is normally only required for certain non-deliverable interest rate swaps (e.g. Brazillian Real (BRL) vs. CETIP Interbank Deposit Rate (CDI)). The value is calculated as follows: Future Value Notional = Notional Amount * (1 + Fixed Rate) ^ (Fixed Rate Day Count Fraction). The currency is the same as the stream notional.">
    cdm.fixml.datatypes.Amt

typeAlias UnderlyingPaymentStreamFutureValueDateAdjusted_t: <"The adjusted value date of the future value amount.">
    cdm.fixml.datatypes.LocalMktDate

typeAlias UnderlyingPaymentStreamRateIndex_t: <"The payment stream\'s floating rate index.">
    string

typeAlias UnderlyingPaymentStreamRateIndexCurvePeriod_t: <"Time unit multiplier for the underlying instrument’s floating rate index.">
    int

typeAlias UnderlyingPaymentStreamRateMultiplier_t: <"A rate multiplier to apply to the floating rate. A multiplier schedule is expressed as explicit multipliers and dates. In the case of a schedule, the step dates may be subject to adjustment in accordance with any adjustments specified in the calculationPeriodDatesAdjustments. The multiplier can be less than or greater than 1 (one). This element should only be included if the multiplier is not equal to 1 (one) for the term of the stream.">
    number

typeAlias UnderlyingPaymentStreamRateSpread_t: <"Spread from floating rate index.">
    cdm.fixml.datatypes.PriceOffset

typeAlias UnderlyingPaymentStreamCapRate_t: <"The cap rate, if any, which applies to the floating rate. The cap rate (strike) is only required where the floating rate on a swap stream is capped at a certain level. The cap rate is assumed to be exclusive of any spread and is a per annum rate, expressed as a decimal. A cap rate of 5% would be represented as 0.05.">
    cdm.fixml.datatypes.Percentage

typeAlias UnderlyingPaymentStreamFloorRate_t: <"The floor rate, if any, which applies to the floating rate. The floor rate (strike) is only required where the floating rate on a swap stream is floored at a certain strike level. The floor rate is assumed to be exclusive of any spread and is a per annum rate, expressed as a decimal. A floor rate of 5% would be represented as 0.05.">
    cdm.fixml.datatypes.Percentage

typeAlias UnderlyingPaymentStreamInitialRate_t: <"The initial floating rate reset agreed between the principal parties involved in the trade. This is assumed to be the first required reset rate for the first regular calculation period. It should only be included when the rate is not equal to the rate published on the source implied by the floating rate index. An initial rate of 5% would be represented as 0.05.">
    cdm.fixml.datatypes.Percentage

typeAlias UnderlyingPaymentStreamFinalRatePrecision_t: <"Specifies the rounding precision in terms of a number of decimal places. Note how a percentage rate rounding of 5 decimal places is expressed as a rounding precision of 7.">
    int

typeAlias UnderlyingPaymentStreamInflationLagPeriod_t: <"Time unit multiplier for the inflation lag period. The lag period is the offsetting period from the payment date which determines the reference period for which the inflation index is observed.">
    int

typeAlias UnderlyingPaymentStreamInflationPublicationSource_t: <"The current main publication source such as relevant web site or a government body.">
    string

typeAlias UnderlyingPaymentStreamInflationInitialIndexLevel_t: <"Initial known index level for the first calculation period.">
    number

typeAlias UnderlyingPaymentStreamInflationFallbackBondApplicable_t: <"Indicates whether a fallback bond as defined in the 2006 ISDA Inflation Derivatives Definitions, sections 1.3 and 1.8, is applicable or not. If not specified, the default value is \"Y\" (True/Yes).">
    cdm.fixml.datatypes.Boolean

typeAlias UnderlyingPaymentStreamNonDeliverableRefCurrency_t: <"The non-deliverable settlement reference currency. Uses ISO 4217 currency codes.">
    cdm.fixml.datatypes.Currency

typeAlias UnderlyingPaymentStreamNonDeliverableFixingDatesBusinessCenter_t: <"The business center calendar used to adjust the payment stream\'s fixing date for the non-deliverable terms, e.g. \"GBLO\".  See http://www.fpml.org/coding-scheme/business-center for standard 4-character code values.">
    string

typeAlias UnderlyingPaymentStreamNonDeliverableFixingDatesRelativeTo_t: <"Specifies the anchor date when the non-deliverable fixing dates are relative to an anchor date.  See http://www.fixtradingcommunity.org/codelists#Relative_To_Date for values.">
    int

typeAlias UnderlyingPaymentStreamNonDeliverableFixingDatesOffsetPeriod_t: <"Time unit multiplier for the relative non-deliverable fixing date offset.">
    int

typeAlias SettlRateFallbackReferencePage_t: <"Identifies the reference \"page\" from the rate source.  When SettlRateFallbackRateSource(40373) = 3 (ISDA Settlement Rate Option) this contains the value from the scheme that reflects the terms of the Annex A to the ISDA 1998 FX and Currency Option Definitions. See: http://www.fpml.org/coding-scheme/settlement-rate-option">
    string

typeAlias UnderlyingNonDeliverableFixingDate_t: <"The non-deliverable fixing date unadjusted or adjusted depending on UnderlyingNonDeliverableFixingDateType(40658).">
    cdm.fixml.datatypes.LocalMktDate

typeAlias UnderlyingSettlRatePostponementMaximumDays_t: <"The maximum number of days to wait for a quote from the disrupted settlement rate option before proceding to this method.">
    int

typeAlias UnderlyingSettlRatePostponementSurvey_t: <"Indicates whether to request a settlement rate quote from the market.">
    cdm.fixml.datatypes.Boolean

typeAlias UnderlyingPaymentScheduleStartDateUnadjusted_t: <"The unadjusted date on which the value is adjusted, or calculated if a future value notional for certain non-deliverable interest rate swaps (e.g. Brazillian Real (BRL) vs. CETIP Interbank Deposit Rate (CDI)), or the start date of a cashflow payment.">
    cdm.fixml.datatypes.LocalMktDate

typeAlias UnderlyingPaymentScheduleEndDateUnadjusted_t: <"The unadjusted end date of a cashflow payment.">
    cdm.fixml.datatypes.LocalMktDate

typeAlias UnderlyingPaymentScheduleNotional_t: <"The notional value for this step, or amount of a cashflow payment.">
    cdm.fixml.datatypes.Amt

typeAlias UnderlyingPaymentScheduleCurrency_t: <"The currency for this step. Uses ISO 4217 currency codes.">
    cdm.fixml.datatypes.Currency

typeAlias UnderlyingPaymentScheduleRate_t: <"The rate value for this step.">
    cdm.fixml.datatypes.Percentage

typeAlias UnderlyingPaymentScheduleRateMultiplier_t: <"A rate multiplier to apply to the floating rate. The multiplier can be less than or greater than 1 (one). This element should only be included if the multiplier is not equal to 1 (one) for the term of the stream.">
    number

typeAlias UnderlyingPaymentScheduleRateSpread_t: <"The spread value for this step.">
    cdm.fixml.datatypes.PriceOffset

typeAlias UnderlyingPaymentScheduleFixedAmount_t: <"The explicit payment amount for this step.">
    cdm.fixml.datatypes.Amt

typeAlias UnderlyingPaymentScheduleFixedCurrency_t: <"The currency of the fixed amount. Uses ISO 4217 currency codes.">
    cdm.fixml.datatypes.Currency

typeAlias UnderlyingPaymentScheduleStepFrequencyPeriod_t: <"Time unit multiplier for the step frequency.">
    int

typeAlias UnderlyingPaymentScheduleStepOffsetValue_t: <"The explicit amount that the notional changes on each step date. This can be a positive or negative amount.">
    cdm.fixml.datatypes.Amt

typeAlias UnderlyingPaymentScheduleStepRate_t: <"The percentage by which the notional changes on each step date. The percentage is either a percentage applied to the initial notional amount or the previous outstanding notional, depending on the value specified in UnderlyingPaymentScheduleStepRelativeTo(40685). The percentage can be either positive or negative.">
