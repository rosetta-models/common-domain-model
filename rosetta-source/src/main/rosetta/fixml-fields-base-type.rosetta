typeAlias AllowableOneSidednessValue_t: <"The maximum amount that execution of one side of a program trade can exceed execution of the other.">
    cdm.fixml.datatypes.Amt

typeAlias AllowableOneSidednessCurr_t: <"The currency that AllowableOneSidednessValue (766) is expressed in if AllowableOneSidednessValue is used.">
