    cdm.fixml.datatypes.LocalMktDate

typeAlias UnderlyingStreamCommoditySettlDateAdjusted_t: <"The adjusted commodity delivery date.">
    cdm.fixml.datatypes.LocalMktDate

typeAlias UnderlyingStreamCommoditySettlMonth_t: <"Specifies a fixed single month for commodity delivery.">
    int

typeAlias UnderlyingStreamCommoditySettlDateRollPeriod_t: <"Time unit multiplier for the commodity delivery date roll.">
    int

typeAlias UnderlyingStreamCommodityXID_t: <"Identifier of this stream commodity for cross referencing elsewhere in the message.">
    string

typeAlias UnderlyingStreamCommodityXIDRef_t: <"Reference to a stream commodity elsewhere in the message.">
    string

typeAlias UnderlyingStreamCommodityAltID_t: <"Alternate security identifier value for the commodity.">
    string

typeAlias UnderlyingStreamCommodityAltIDSource_t: <"Identifies the class or source of the alternate commodity security identifier.">
    string

typeAlias UnderlyingStreamCommodityDataSourceID_t: <"Data source identifier.">
    string

typeAlias UnderlyingStreamCommoditySettlTotalHours_t: <"Sum of the hours specified in UnderlyingStreamCommoditySettlTimeGrp.">
    int

typeAlias UnderlyingStreamCommoditySettlStart_t: <"The start time for commodity settlement where delivery occurs over time. The time format is specified by the settlement time type.">
    string

typeAlias UnderlyingStreamCommoditySettlEnd_t: <"The end time for commodity settlement where delivery occurs over time. The time format is specified by the settlement time type.">
    string

typeAlias UnderlyingStreamCommoditySettlCountry_t: <"Specifies the country where delivery takes place. Uses ISO 3166 2-character country code.">
    cdm.fixml.datatypes.Country

typeAlias UnderlyingStreamCommoditySettlTimeZone_t: <"Commodity delivery timezone specified as \"prevailing\" rather than \"standard\" or \"daylight\".  See http://www.fixtradingcommunity.org/codelists#Prevailing_Timezones for code list of applicable prevailing timezones.">
    string

typeAlias UnderlyingStreamCommoditySettlPeriodNotional_t: <"Specifies the delivery quantity associated with this settlement period.">
    cdm.fixml.datatypes.Qty

typeAlias UnderlyingStreamCommoditySettlPeriodFrequencyPeriod_t: <"Time unit multiplier for the settlement period frequency.">
    int

typeAlias UnderlyingStreamCommoditySettlPeriodPrice_t: <"The settlement period price.">
    cdm.fixml.datatypes.Price

typeAlias UnderlyingStreamCommoditySettlPeriodPriceCurrency_t: <"The currency of the settlement period price. Uses ISO 4217 currency codes.">
    cdm.fixml.datatypes.Currency

typeAlias UnderlyingStreamCommoditySettlPeriodXID_t: <"Identifier of this settlement period for cross referencing elsewhere in the message.">
    string

typeAlias UnderlyingStreamCommoditySettlPeriodXIDRef_t: <"Cross reference to another settlement period for duplicating its properties.">
    string

typeAlias UnderlyingStreamXID_t: <"Identifier of this UnderlyingStream for cross referencing elsewhere in the message.">
    string

typeAlias UnderlyingAdditionalTermBondIssuer_t: <"Issuer of the bond.">
    string

typeAlias UnderlyingStreamNotionalXIDRef_t: <"Cross reference to another UnderlyingStream notional for duplicating its properties.">
    string

typeAlias UnderlyingStreamNotionalFrequencyPeriod_t: <"Time unit multiplier for the swap stream\'s notional frequency.">
    int

typeAlias UnderlyingStreamTotalNotional_t: <"Specifies the total notional or delivery quantity over the term of the contract.">
    cdm.fixml.datatypes.Qty

typeAlias EncodedUnderlyingAdditionalTermBondIssuerLen_t: <"Byte length of encoded (non-ASCII characters) EncodedUnderlyingAdditionalTermBondIssuer(42026) field.">
    cdm.fixml.datatypes.Length

typeAlias EncodedUnderlyingAdditionalTermBondIssuer_t: <"Encoded (non-ASCII characters) representation of the UnderlyingAdditionalTermBondIssuer(42017) field in the encoded format specified via the MessageEncoding (347) field. If used, the ASCII (English) representation should also be specified in the UnderlyingAdditionalTermBondIssuer(42017) field.">
    string

typeAlias UnderlyingAdditionalTermBondCouponRate_t: <"Coupon rate of the bond. See also CouponRate(223).">
    cdm.fixml.datatypes.Percentage

typeAlias UnderlyingAdditionalTermBondMaturityDate_t: <"The maturity date of the bond.">
    cdm.fixml.datatypes.LocalMktDate

typeAlias UnderlyingAdditionalTermBondParValue_t: <"The par value of the bond.">
    cdm.fixml.datatypes.Amt

typeAlias UnderlyingAdditionalTermBondCurrentTotalIssuedAmount_t: <"Total issued amount of the bond.">
    cdm.fixml.datatypes.Amt

typeAlias UnderlyingAdditionalTermBondCouponFrequencyPeriod_t: <"Time unit multiplier for the frequency of the bond\'s coupon payment.">
    int

typeAlias UnderlyingAdditionalTermConditionPrecedentBondIndicator_t: <"Indicates whether the condition precedent bond is applicable. The swap contract is only valid if the bond is issued and if there is any dispute over the terms of fixed stream then the bond terms would be used.">
    cdm.fixml.datatypes.Boolean

typeAlias UnderlyingAdditionalTermDiscrepancyClauseIndicator_t: <"Indicates whether the discrepancy clause is applicable.">
    cdm.fixml.datatypes.Boolean

typeAlias UnderlyingCashSettlDealer_t: <"Identifies the dealer from whom price quotations for the reference obligation are obtained for the purpose of cash settlement valuation calculation.">
    string

typeAlias UnderlyingCashSettlCurrency_t: <"Specifies the currency the UnderlyingCashSettlAmount(42054) is denominated in. Uses ISO 4217 currency codes.">
    cdm.fixml.datatypes.Currency

typeAlias UnderlyingCashSettlValuationFirstBusinessDayOffset_t: <"The number of business days after settlement conditions have been satisfied, when the calculation agent is to obtain a price quotation on the reference obligation for purposes of cash settlement.">
    int

typeAlias UnderlyingCashSettlValuationSubsequentBusinessDaysOffset_t: <"The number of business days between successive valuation dates when multiple valuation dates are applicable for cash settlement.">
    int

typeAlias UnderlyingCashSettlNumOfValuationDates_t: <"Where multiple valuation dates are specified as being applicable for cash settlement, this element specifies the number of applicable valuation dates.">
    int

typeAlias UnderlyingCashSettlValuationTime_t: <"Time of valuation.">
    time

typeAlias UnderlyingCashSettlBusinessCenter_t: <"Identifies the business center calendar used at valuation time for cash settlement purposes e.g. \"GBLO\".  See http://www.fpml.org/coding-scheme/business-center for standard 4-character code values.">
    string

typeAlias UnderlyingCashSettlQuoteAmount_t: <"When determining the cash settlement amount, if weighted average price quotes are to be obtained for the reference obligation, this is the upper limit to the outstanding principal balance of the reference obligation for which the quote should be obtained. If not specified, the ISDA definitions provide for a fallback amount equal to floating rate payer calculation amount.">
    cdm.fixml.datatypes.Amt

typeAlias UnderlyingCashSettlQuoteCurrency_t: <"Specifies the currency the UnderlyingCashSettlQuoteAmount(42049) is denominated in. Uses ISO 4217 currency codes.">
    cdm.fixml.datatypes.Currency

typeAlias UnderlyingCashSettlMinimumQuoteAmount_t: <"When determining the cash settlement amount, if weighted average price quotes are to be obtained for the reference obligation, this is the minimum intended threshold amount of outstanding principal balance of the reference obligation for which the quote should be obtained. If not specified, the ISDA definitions provide for a fallback amount of the lower of either USD1,000,000 (or its equivalent in the relevant obligation currency) or the (minimum) quoted amount.">
    cdm.fixml.datatypes.Amt

typeAlias UnderlyingCashSettlMinimumQuoteCurrency_t: <"Specifies the currency the UnderlyingCashSettlQuoteAmount(42049) is denominated in. Uses ISO 4217 currency codes.">
    cdm.fixml.datatypes.Currency

typeAlias UnderlyingCashSettlBusinessDays_t: <"The number of business days used in the determination of the cash settlement payment date.">
    int

typeAlias UnderlyingCashSettlAmount_t: <"The amount paid between the trade parties, seller to the buyer, for cash settlement on the cash settlement date.">
    cdm.fixml.datatypes.Amt

typeAlias UnderlyingCashSettlRecoveryFactor_t: <"Used for fixed recovery, this specifies the recovery level as determined at contract inception, to be applied in the event of a default. The factor is used to calculate the amount paid by the seller to the buyer for cash settlement on the cash settlement date. The amount is calculated is (1 - UnderlyingCashSettlRecoveryFactor(42055)) x floating rate payer calculation amount. The currency is derived from the floating rate payer calculation amount.">
    number

typeAlias UnderlyingCashSettlFixedTermIndicator_t: <"Indicates whether fixed settlement is applicable or not applicable in a recovery lock.">
    cdm.fixml.datatypes.Boolean

typeAlias UnderlyingCashSettlAccruedInterestIndicator_t: <"Indicates whether accrued interest is included or not in the value provided in UnderlyingCashSettlAmount(42054).  For cash settlement this specifies whether quotations should be obtained inclusive or not of accrued interest.  For physical settlement this specifies whether the buyer should deliver the obligation with an outstanding principal balance that includes or excludes accrued interest.">
    cdm.fixml.datatypes.Boolean

typeAlias UnderlyingCashSettlTermXID_t: <"Name referenced from UnderlyingSettlementTermXIDRef(41315).">
    string

typeAlias UnderlyingPhysicalSettlCurrency_t: <"Currency of physical settlement. Uses ISO 4217 currency codes.">
    cdm.fixml.datatypes.Currency

typeAlias UnderlyingPhysicalSettlBusinessDays_t: <"A number of business days. Its precise meaning is dependent on the context in which this element is used.">
    int

typeAlias UnderlyingPhysicalSettlMaximumBusinessDays_t: <"A maximum number of business days. Its precise meaning is dependent on the context in which this element is used. Intended to be used to limit a particular ISDA fallback provision.">
    int

typeAlias UnderlyingPhysicalSettlTermXID_t: <"A named string value referenced by UnderlyingSettlTermXIDRef(41315).">
    string

typeAlias UnderlyingPhysicalSettlDeliverableObligationType_t: <"Specifies the type of delivery obligation applicable for physical settlement.  See http://www.fixtradingcommunity.org/codelists#Deliverable_Obligation_Types for code list for applicable deliverable obligation types.">
    string

typeAlias UnderlyingPhysicalSettlDeliverableObligationValue_t: <"Physical settlement delivery obligation value appropriate to UnderlyingPhysicalSettlDeliverableObligationType(42066).  See http://www.fixtradingcommunity.org/codelists#Deliverable_Obligation_Types for applicable obligation type values.">
    string

typeAlias UnderlyingProtectionTermNotional_t: <"The notional amount of protection coverage for a floating rate.">
    cdm.fixml.datatypes.Amt

typeAlias UnderlyingProtectionTermCurrency_t: <"The currency of UnderlyingProtectionTermNotional(42069). Uses ISO 4217 currency codes.">
    cdm.fixml.datatypes.Currency

typeAlias UnderlyingProtectionTermSellerNotifies_t: <"The notifying party is the party that notifies the other party when a credit event has occurred by means of a credit event notice. If more than one party is referenced as being the notifying party then either party may notify the other of a credit event occurring.  UnderlyingProtectionTermSellerNotifies(42071)=Y indicates that the seller notifies.">
    cdm.fixml.datatypes.Boolean

typeAlias UnderlyingProtectionTermBuyerNotifies_t: <"The notifying party is the party that notifies the other party when a credit event has occurred by means of a credit event notice. If more than one party is referenced as being the notifying party then either party may notify the other of a credit event occurring.  UnderlyingProtectionTermBuyerNotifies(42072)=Y indicates that the buyer notifies.">
    cdm.fixml.datatypes.Boolean

typeAlias UnderlyingProtectionTermEventBusinessCenter_t: <"When used, the business center indicates the local time of the business center that replaces the Greenwich Mean Time in Section 3.3 of the 2003 ISDA Credit Derivatives Definitions.  See http://www.fpml.org/coding-scheme/business-center for standard 4-character code values.">
    string

typeAlias UnderlyingProtectionTermStandardSources_t: <"Indicates whether ISDA defined Standard Public Sources are applicable (UnderlyingProtectionTermStandardSources(42074)=Y) or not.">
    cdm.fixml.datatypes.Boolean

typeAlias UnderlyingProtectionTermEventMinimumSources_t: <"The minimum number of the specified public information sources that must publish information that reasonably confirms that a credit event has occurred. The market convention is two.">
    int

typeAlias UnderlyingProtectionTermXID_t: <"A named string value referenced by UnderlyingProtectionTermXIDRef(41314).">
    string

typeAlias UnderlyingProtectionTermEventType_t: <"Specifies the type of credit event applicable to the protection terms.  See http://www.fixtradingcommunity.org/codelists#Protection_Term_Event_Types for code list of applicable event types.">
    string

typeAlias UnderlyingProtectionTermEventValue_t: <"Protection term event value appropriate to UnderlyingProtectionTermEventType(42078).  See http://www.fixtradingcommunity.org/codelists#Protection_Term_Event_Types for applicable event type values.">
    string

typeAlias UnderlyingProtectionTermEventCurrency_t: <"Applicable currency if UnderlyingProtectionTermEventValue(42079) is an amount. Uses ISO 4217 currency codes.">
    cdm.fixml.datatypes.Currency

typeAlias UnderlyingProtectionTermEventPeriod_t: <"Time unit multiplier for protection term events.">
    int

typeAlias UnderlyingProtectionTermEventRateSource_t: <"Rate source for events that specify a rate source, e.g. Floating rate interest shortfall.">
    string

typeAlias UnderlyingProtectionTermObligationType_t: <"Specifies the type of obligation applicable to the protection terms.  See http://www.fixtradingcommunity.org/codelists#Protection_Term_Obligation_Types for code list of applicable obligation types.">
    string

typeAlias UnderlyingProtectionTermObligationValue_t: <"Protection term obligation value appropriate to UnderlyingProtectionTermObligationType(42088).  See http://www.fixtradingcommunity.org/codelists#Protection_Term_Obligation_Types for applicable obligation type values.">
    string

typeAlias UnderlyingProtectionTermEventNewsSource_t: <"Newspaper or electronic news service or source that may publish relevant information used in the determination of whether or not a credit event has occurred.">
    string

typeAlias UnderlyingProvisionCashSettlPaymentDateRelativeTo_t: <"Specifies the anchor date when the cash settlement payment date is relative to an anchor date.  See http://www.fixtradingcommunity.org/codelists#Relative_To_Date for values.">
    int

typeAlias UnderlyingProvisionCashSettlPaymentDateOffsetPeriod_t: <"Time unit multiplier for the relative cash settlement payment date offset.">
    int

typeAlias UnderlyingProvisionCashSettlPaymentDateRangeFirst_t: <"First date in range when a settlement date range is provided.">
    cdm.fixml.datatypes.LocalMktDate

typeAlias UnderlyingProvisionCashSettlPaymentDateRangeLast_t: <"Last date in range when a settlement date range is provided.">
    cdm.fixml.datatypes.LocalMktDate

typeAlias UnderlyingProvisionCashSettlPaymentDate_t: <"The cash settlement payment date, unadjusted or adjusted depending on UnderlyingProvisionCashSettlPaymentDateType(42101).">
    cdm.fixml.datatypes.LocalMktDate

typeAlias UnderlyingProvisionCashSettlQuoteReferencePage_t: <"Identifies the reference \"page\" from the quote source.">
    string

typeAlias UnderlyingProvisionCashSettlValueTime_t: <"A time specified in 24-hour format, e.g. 11am would be represented as 11:00:00. The time of the cash settlement valuation date when the cash settlement amount will be determined according to the cash settlement method if the parties have not otherwise been able to agree to the cash settlement amount.">
    time

typeAlias UnderlyingProvisionCashSettlValueTimeBusinessCenter_t: <"Identifies the business center calendar used with the provision\'s cash settlement valuation time.  See http://www.fpml.org/coding-scheme/business-center for standard 4-character code values.">
    string

typeAlias UnderlyingProvisionCashSettlValueDateRelativeTo_t: <"Specifies the anchor date when the cash settlement value date is relative to an anchor date.  See http://www.fixtradingcommunity.org/codelists#Relative_To_Date for values.">
    int

typeAlias UnderlyingProvisionCashSettlValueDateOffsetPeriod_t: <"Time unit multiplier for the relative cash settlement value date offset.">
    int

typeAlias UnderlyingProvisionCashSettlValueDateAdjusted_t: <"The adjusted cash settlement value date.">
    cdm.fixml.datatypes.LocalMktDate

typeAlias UnderlyingProvisionOptionExerciseFixedDate_t: <"A predetermined option exercise date, unadjusted or adjusted depending on UnderlyingProvisionOptionExerciseFixedDateType(42114).">
    cdm.fixml.datatypes.LocalMktDate

typeAlias UnderlyingProvisionOptionExerciseEarliestDateOffsetPeriod_t: <"Time unit multiplier for the interval to the first (and possibly only) exercise date in the exercise period.">
    int

typeAlias UnderlyingProvisionOptionExerciseFrequencyPeriod_t: <"Time unit multiplier for the frequency of subsequent exercise dates in the exercise period following the earliest exercise date. An interval of 1 day should be used to indicate an American style exercise frequency.">
    int

typeAlias UnderlyingProvisionOptionExerciseStartDateUnadjusted_t: <"The unadjusted first day of the exercise period for an American style option.">
    cdm.fixml.datatypes.LocalMktDate

typeAlias UnderlyingProvisionOptionExerciseStartDateRelativeTo_t: <"Specifies the anchor date when the option exercise start date is relative to an anchor date.  See http://www.fixtradingcommunity.org/codelists#Relative_To_Date for values.">
    int

typeAlias UnderlyingProvisionOptionExerciseStartDateOffsetPeriod_t: <"Time unit multiplier for the relative option exercise start date offset.">
    int

typeAlias UnderlyingProvisionOptionExerciseStartDateAdjusted_t: <"The adjusted first day of the exercise period for an American style option.">
    cdm.fixml.datatypes.LocalMktDate

typeAlias UnderlyingProvisionOptionExercisePeriodSkip_t: <"The number of periods in the referenced date schedule that are between each date in the relative date schedule. Thus a skip of 2 would mean that dates are relative to every second date in the referenced schedule. If present this should have a value greater than 1.">
    int

typeAlias UnderlyingProvisionOptionExerciseBoundsFirstDateUnadjusted_t: <"The unadjusted first date of a schedule. This can be used to restrict the range of exercise dates when they are relative.">
    cdm.fixml.datatypes.LocalMktDate

typeAlias UnderlyingProvisionOptionExerciseBoundsLastDateUnadjusted_t: <"The unadjusted last date of a schedule. This can be used to restrict the range of exercise dates when they are relative.">
    cdm.fixml.datatypes.LocalMktDate

typeAlias UnderlyingProvisionOptionExerciseEarliestTime_t: <"The earliest time at which notice of exercise can be given by the buyer to the seller (or seller\'s agent) i) on the expriation date, in the case of a European style option, (ii) on each bermuda option exercise date and the expiration date, in the case of a Bermuda style option the commencement date to, and including, the expiration date, in the case of an American option.">
    time

typeAlias UnderlyingProvisionOptionExerciseEarliestTimeBusinessCenter_t: <"Identifies the business center calendar used with the provision\'s earliest time for notice of exercise.  See http://www.fpml.org/coding-scheme/business-center for standard 4-character code values.">
    string

typeAlias UnderlyingProvisionOptionExerciseLatestTime_t: <"For a Bermuda or American style option, the latest time on an exercise business day (excluding the expiration date) within the exercise period that notice can be given by the buyer to the seller or seller\'s agent. Notice of exercise given after this time will be deemed to have been given on the next exercise business day.">
    time

typeAlias UnderlyingProvisionOptionExerciseLatestTimeBusinessCenter_t: <"Identifies the business center calendar used with the provision\'s latest time for notice of exercise.  See http://www.fpml.org/coding-scheme/business-center for standard 4-character code values.">
    string

typeAlias UnderlyingProvisionOptionExpirationDateUnadjusted_t: <"The unadjusted last day within an exercise period for an American style option. For a European style option it is the only day within the exercise period.">
    cdm.fixml.datatypes.LocalMktDate

typeAlias UnderlyingProvisionOptionExpirationDateRelativeTo_t: <"Specifies the anchor date when the option expiration date is relative to an anchor date.  See http://www.fixtradingcommunity.org/codelists#Relative_To_Date for values.">
    int

typeAlias UnderlyingProvisionOptionExpirationDateOffsetPeriod_t: <"Time unit multiplier for the relative option expiration date offset.">
    int

typeAlias UnderlyingProvisionOptionExpirationDateAdjusted_t: <"The adjusted last date within an exercise period for an American style option. For a European style option it is the only date within the exercise period.">
    cdm.fixml.datatypes.LocalMktDate

typeAlias UnderlyingProvisionOptionExpirationTime_t: <"The latest time for exercise on the expiration date.">
    time

typeAlias UnderlyingProvisionOptionExpirationTimeBusinessCenter_t: <"Identifies the business center calendar used with the provision\'s latest exercise time on expiration date.  See http://www.fpml.org/coding-scheme/business-center for standard 4-character code values.">
    string

typeAlias UnderlyingProvisionOptionRelevantUnderlyingDateUnadjusted_t: <"The unadjusted date on the underlying set by the exercise of an option. What this date is depends on the option (e.g. in a swaption it is the swap effective date, in an extendible/cancelable provision it is the swap termination date).">
    cdm.fixml.datatypes.LocalMktDate

typeAlias UnderlyingProvisionOptionRelevantUnderlyingDateRelativeTo_t: <"Specifies the anchor date when the date relevant to the underlying trade on exercise is relative to an anchor date.  See http://www.fixtradingcommunity.org/codelists#Relative_To_Date for values.">
    int

typeAlias UnderlyingProvisionOptionRelevantUnderlyingDateOffsetPeriod_t: <"Time unit multiplier for the relative option relevant underlying date offset.">
    int

typeAlias UnderlyingProvisionOptionRelevantUnderlyingDateAdjusted_t: <"The adjusted date on the underlying set by the exercise of an option. What this date is depends on the option (e.g. in a swaption it is the swap effective date, in an extendible/cancelable provision it is the swap termination date).">
    cdm.fixml.datatypes.LocalMktDate

typeAlias UnderlyingProvisionDateUnadjusted_t: <"The unadjusted date of the provision.">
    cdm.fixml.datatypes.LocalMktDate

typeAlias UnderlyingProvisionDateAdjusted_t: <"The adjusted date of the provision.">
    cdm.fixml.datatypes.LocalMktDate

typeAlias UnderlyingProvisionDateTenorPeriod_t: <"Time unit multiplier for the provision\'s tenor period.">
    int

typeAlias UnderlyingProvisionOptionExerciseMultipleNotional_t: <"A notional amount which restricts the amount of notional that can be exercised when partial exercise or multiple exercise is applicable. The integral multiple amount defines a lower limit of notional that can be exercised and also defines a unit multiple of notional that can be exercised, i.e. only integer multiples of this amount can be exercised.">
    cdm.fixml.datatypes.Amt

typeAlias UnderlyingProvisionOptionExerciseMinimumNotional_t: <"The minimum notional amount that can be exercised on a given exercise date.">
    cdm.fixml.datatypes.Amt

typeAlias UnderlyingProvisionOptionExerciseMaximumNotional_t: <"The maximum notional amount that can be exercised on a given exercise date.">
    cdm.fixml.datatypes.Amt

typeAlias UnderlyingProvisionOptionMinimumNumber_t: <"The minimum number of options that can be exercised on a given exercise date.">
    int

typeAlias UnderlyingProvisionOptionMaximumNumber_t: <"The maximum number of options that can be exercised on a given exercise date. If the number is not specified, it means that the maximum number of options corresponds to the remaining unexercised options.">
    int

typeAlias UnderlyingProvisionOptionExerciseConfirmation_t: <"Used to indicate whether follow-up confirmation of exercise (written or electronic) is required following telephonic notice by the buyer to the seller or seller\'s agent.">
    cdm.fixml.datatypes.Boolean

typeAlias UnderlyingProvisionCashSettlCurrency_t: <"Specifies the currency of settlement. Uses ISO 4217 currency codes.">
    cdm.fixml.datatypes.Currency

typeAlias UnderlyingProvisionCashSettlCurrency2_t: <"Specifies the currency of settlement for a cross-currency provision. Uses ISO 4217 currency codes.">
    cdm.fixml.datatypes.Currency

typeAlias UnderlyingProvisionText_t: <"Free form text to specify additional information or enumeration description when a standard value does not apply.">
    string

typeAlias EncodedUnderlyingProvisionTextLen_t: <"Byte length of encoded (non-ASCII characters) EncodedUnderlyingProvisionText(42712) field.">
    cdm.fixml.datatypes.Length

typeAlias EncodedUnderlyingProvisionText_t: <"Encoded (non-ASCII characters) representation of the UnderlyingProvisionText(42170) field in the encoded format specified via the MessageEncoding (347) field. If used, the ASCII (English) representation should also be specified in the UnderlyingProvisionText(42170) field.">
    string

typeAlias UnderlyingProvisionPartyID_t: <"The party identifier for the payment settlement party.">
    string

typeAlias UnderlyingProvisionPartySubID_t: <"Underlying provision party sub-identifier, if applicable for UnderlyingProvisionPartyID(42174).">
    string

typeAlias UnderlyingProvisionCashSettlPaymentDateBusinessCenter_t: <"The business center calendar used to adjust the provision\'s cash settlement payment\'s termination, or relative termination, date, e.g. \"GBLO\".  See http://www.fpml.org/coding-scheme/business-center for standard 4-character code values.">
    string

typeAlias UnderlyingProvisionCashSettlValueDateBusinessCenter_t: <"The business center calendar used to adjust the cash settlement valuation date, e.g. \"GBLO\".  See http://www.fpml.org/coding-scheme/business-center for standard 4-character code values.">
    string

typeAlias UnderlyingProvisionOptionExerciseBusinessCenter_t: <"The business center calendar used to adjust the underlying instrument\'s provision\'s option exercise date, e.g. \"GBLO\".  See http://www.fpml.org/coding-scheme/business-center for standard 4-character code values.">
    string

typeAlias UnderlyingProvisionOptionExpirationDateBusinessCenter_t: <"The business center calendar used to adjust the underlying instrument\'s provision\'s option expiration date, e.g. \"GBLO\".  See http://www.fpml.org/coding-scheme/business-center for standard 4-character code values.">
    string

typeAlias UnderlyingProvisionOptionRelevantUnderlyingDateBusinessCenter_t: <"The business center calendar used to adjust the underlying instrument\'s provision\'s option underlying date, e.g. \"GBLO\".  See http://www.fpml.org/coding-scheme/business-center for standard 4-character code values.">
    string

