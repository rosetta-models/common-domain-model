    cdm.fixml.datatypes.Amt

typeAlias LegPaymentScheduleFixedCurrency_t: <"The currency of the fixed amount. Uses ISO 4217 currency codes.">
    cdm.fixml.datatypes.Currency

typeAlias LegPaymentScheduleStepFrequencyPeriod_t: <"Time unit multiplier for the step frequency.">
