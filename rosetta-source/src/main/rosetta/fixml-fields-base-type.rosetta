    cdm.fixml.datatypes.Percentage

typeAlias LegPaymentStreamFixedAmount_t: <"The leg instrument payment stream\'s fixed payment amount. In a CDS, this can be an alternative to LegPaymentStreamRate(40326).">
    cdm.fixml.datatypes.Amt

