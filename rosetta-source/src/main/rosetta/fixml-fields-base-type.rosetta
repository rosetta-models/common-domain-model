    int

typeAlias LegPaymentStreamFirstPaymentDateUnadjusted_t: <"The unadjusted first payment date.">
    cdm.fixml.datatypes.LocalMktDate

typeAlias LegPaymentStreamLastRegularPaymentDateUnadjusted_t: <"The unadjusted last regular payment date.">
    cdm.fixml.datatypes.LocalMktDate

typeAlias LegPaymentStreamPaymentDateRelativeTo_t: <"Specifies the anchor date when payment dates are relative to an anchor date.  See http://www.fixtradingcommunity.org/codelists#Relative_To_Date for values.">
    int

